{
  "name": "open-source-nvr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev:legacy": "pnpm --filter @nvr/legacy-frontend dev",
    "dev:dashboard": "pnpm --filter @nvr/dashboard dev",
    "dev:server": "pnpm --filter @nvr/server server",
    "server": "pnpm --filter @nvr/server server",
    "test": "turbo run test",
    "test:watch": "pnpm --filter @nvr/server test:watch",
    "test:coverage": "pnpm --filter @nvr/server test:coverage"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
